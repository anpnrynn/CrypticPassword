<?xml version="1.0" encoding="UTF-8"?>
<project name="CrypticPasswordSwingNB" default="jar" basedir=".">
    <property file="nbproject/project.properties"/>

    <target name="init">
        <mkdir dir="${build.classes.dir}"/>
        <mkdir dir="${dist.dir}"/>
    </target>

    <target name="compile" depends="init">
        <javac srcdir="${src.dir}" destdir="${build.classes.dir}" source="${javac.source}" target="${javac.target}" debug="${javac.debug}" includeantruntime="false"/>
    </target>

    <target name="jar" depends="compile">
        <jar destfile="${dist.jar}" basedir="${build.classes.dir}" manifest="${manifest.file}" compress="${jar.compress}"/>
        <echo message="Built ${dist.jar}"/>
    </target>

    <target name="run" depends="jar">
        <java jar="${dist.jar}" fork="true"/>
    </target>

    <target name="clean">
        <delete dir="${build.dir}"/>
        <delete dir="${dist.dir}"/>
    </target>
</project>
